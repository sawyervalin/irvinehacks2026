{
  "manifest_version": 3,
  "name": "Constryke",
  "version": "1.0.0",
  "description": "Constryke — scan Gmail for wire fraud signals before you close.",
  "permissions": ["identity"],
  "host_permissions": ["https://gmail.googleapis.com/*"],
  "optional_host_permissions": ["http://localhost:3000/*"],
  "oauth2": {
    "client_id": "881267663994-50da7mgeim5esl6h1arei8tdeeetqst4.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/gmail.readonly"]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Constryke",
    "default_popup": "popup.html"
  }
}
